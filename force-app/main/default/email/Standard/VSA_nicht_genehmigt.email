<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Sehr geehrte/r&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.Makler__c}</font><span style="font-family: Helvetica, sans-serif;">,</span></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><font face="Helvetica, sans-serif" size="4">vielen Dank für die Einreichung der VSA. Leider wurde diese nach interner Prüfung abgelehnt.&nbsp;</font></font><span style="font-family: Helvetica, sans-serif; font-size: large;"><br><br>Immobilie:&nbsp;</span><font face="Helvetica, sans-serif" size="4">{!Opportunity.Immobilie__c}</font><font face="arial" style="font-size: 12pt;">&nbsp;<br></font><font face="Helvetica, sans-serif" size="4">Teilobjekt: {!Opportunity.Appartement__c}</font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000" size="4">&nbsp;</font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Bei Fragen zu diesem Prozess steht Ihnen Ihr Maklerbetreuer</font></font><span style="font-family: Helvetica, sans-serif;">&nbsp;gern zur Verfügung. Zusätzlich können Sie Kontakt zum Finanzierungsberater aufnehmen:</span></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><span style="font-family: Helvetica, sans-serif;"><br></span></font></p><p style="margin-bottom: 0in; font-size: 12pt;"><font size="4"><span style="font-family: Helvetica, sans-serif;"><b>Name:&nbsp;</b></span></font><span style="font-family: Helvetica, sans-serif; font-size: large;">{!Opportunity.Finanzierungsberater__c}</span></p><p style="margin-bottom: 0in; font-size: 12pt;"><font size="4"><span style="font-family: Helvetica, sans-serif;"><b>E-Mail:</b></span></font><span style="font-family: Helvetica, sans-serif; font-size: large;">&nbsp;{!Opportunity.EmailFinanzierungsberater__c}</span></p><p style="margin-bottom: 0in; font-size: 12pt;"><font size="4"><span style="font-family: Helvetica, sans-serif;"><b>Telefon:&nbsp;</b></span></font><span style="font-family: Helvetica, sans-serif; font-size: large;">{!Opportunity.TelefonFinanzierungsberater__c}</span></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000"><font face="Helvetica, sans-serif" size="4">Mit freundlichen Grüßen</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000"><font face="Helvetica, sans-serif"><font size="4">Ihr Carestone Team</font></font></font></p>]]></td>

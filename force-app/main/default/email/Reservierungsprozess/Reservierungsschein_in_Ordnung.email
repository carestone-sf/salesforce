<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Sehr geehrte/r&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.Makler__c}</font><span style="font-family: Helvetica, sans-serif;">,</span></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000"><font face="Helvetica, sans-serif" size="4">der Reservierungsschein für:</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Interessent:&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.Potenzieller_Kunde__c}</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Objekt:&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.Immobilie__c}</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Teilobjekt:&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.Appartement__c}</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Reserviert bis:&nbsp;</font></font><font face="Helvetica, sans-serif">{!Opportunity.reserviert_bis__c}</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4">wurde überprüft und akzeptiert. Sie haben nun 3 Tage Zeit um uns die folgenden Unterlagen zu senden:</font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4"><b>Finanzierung:</b></font></p><p style="color: rgb(0, 0, 0); margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4">- VSA</font></p><p style="color: rgb(0, 0, 0); margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4">- Die letzten 3 Gehaltsabrechnungen</font></p><p style="margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4" style="color: rgb(0, 0, 0);">-&nbsp;</font><font face="Helvetica, sans-serif" size="4">Einkommensteuerbescheid</font></p><p style="margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4"><br></font></p><p style="margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4"><b>Eigenkapitalzahlung:</b></font></p><p style="margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4">- VSA</font></p><p style="margin-bottom: 0in;"><font face="Helvetica, sans-serif" size="4">- EK Nachweis</font></p><div style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><font face="arial" size="4"><br></font></div><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><font color="#000000"><font face="Helvetica, sans-serif">Bei Fragen zu diesem Prozess steht Ihnen Ihr Maklerbetreuer</font></font><span style="font-family: Helvetica, sans-serif;">&nbsp;gern zur Verfügung.</span></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000"><font face="Helvetica, sans-serif" size="4">Mit freundlichen Grüßen</font></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font size="4"><br></font></p><p style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin-bottom: 0in;"><font color="#000000"><font face="Helvetica, sans-serif"><font size="4">Ihr Carestone Team</font></font></font></p>]]></td>

        <name>var_ObjectName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Variable um bei der Übergabe der Fehlermeldung aus dem Vor-Flow auf Basis einen festen Wert abzuspeichern, weil kein Objektname ermittelt werden konnte.</description>
        <name>var_ObjectNameNotExists</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>&apos;Objekt nicht ermittelbar&apos;</stringValue>
        </value>
    </variables>
    <variables>
        <description>Datensatz-Variable vom Objekt &apos;Monitoring&apos; in den vom gestarteten Flow die Inhalte einer Fehlermeldung weitergegeben werden, damit in diesem Flow der Datensatz für das Monitoring-Objekt erstellt werden kann.</description>
        <name>varRec_Monitoring</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>Monitoring__c</objectType>
    </variables>
</Flow>

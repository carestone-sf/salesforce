            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_ObjectName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>get_Object.QualifiedApiName</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>create_Monitoring</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Prüft, ob zum Datensatz ein Salesforce-Objekt gefunden werden konnte.</description>
        <name>dec_ObjectExists</name>
        <label>dec_ObjectExists</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>ass_ObjectNo</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>dec_ObjectExists_no</defaultConnectorLabel>
        <rules>
            <name>dec_ObjectExists_yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_Object</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ass_ObjectYes</targetReference>
            </connector>
            <label>dec_ObjectExists_yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>dec_varRec_Ok</name>
        <label>dec_varRec_Ok</label>

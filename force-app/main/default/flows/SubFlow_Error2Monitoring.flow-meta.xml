<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <assignments>
        <description>Zuordnung/Ersetzung der Datensatz-ID gegen einen festgeschriebenen Hinweis, weil kein Objekt ermittelt werden konnte.</description>
        <name>ass_ObjectNo</name>
        <label>ass_ObjectNo</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varRec_Monitoring.SektionObjekt__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>var_ObjectNameNotExists</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_ObjectName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>var_ObjectNameNotExists</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>create_Monitoring</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Zuordnung/Ersetzung der Datensatz-ID gegen den Objekt-Namen in den noch folgenden benötigten Artifakten.</description>
        <name>ass_ObjectYes</name>
        <label>ass_ObjectYes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>varRec_Monitoring.SektionObjekt__c</assignToReference>
            <operator>Assign</operator>
            <value>

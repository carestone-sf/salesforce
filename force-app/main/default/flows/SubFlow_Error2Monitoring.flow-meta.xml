    <description>SubFlow, der die Details einer ErrorMessage in einen zentralen Monitoring-Datensatz im zentralen Administrations-Management zur Verfügung stellt.</description>
    <environments>Default</environments>
    <formulas>
        <description>Objekt-KeyPrefix-Ermittlung auf Basis der ersten 3 Zeichen aus der übergebenen DatensatzID.</description>
        <name>for_KeyPrefix</name>
        <dataType>String</dataType>
        <expression>LEFT({!varRec_Monitoring.Id},3)</expression>
    </formulas>
    <formulas>
        <description>Ganzer Name des aktuellen Benutzers für die vollständige Übergabe an das Monitoring.</description>
        <name>for_UserFullName</name>
        <dataType>String</dataType>
        <expression>{!$User.FirstName}&amp;&quot; &quot;&amp;{!$User.LastName}</expression>
    </formulas>
    <interviewLabel>AutoLaunched - Error2Monitoring {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SubFlow - Error2Monitoring</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Erstellt aus den zugeordneten Informationen aus der Fehlermeldung jetzt den Datensatz im Monitoring-Objekt.</description>
        <name>create_Monitoring</name>
        <label>create_Monitoring</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>create_MonitoringError</targetReference>
        </faultConnector>
        <inputReference>varRec_Monitoring</inputReference>
    </recordCreates>
    <recordCreates>
        <description>Sollte die Erstellung der &apos;Fehlermeldung&apos; im Monitoring selber einen Fehler ergeben, wird dieser Fehler hier an das Monitoring übergeben.</description>
        <name>create_MonitoringError</name>
        <label>create_MonitoringError</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Aktion__c</field>
            <value>
                <stringValue>Flow Monitoring-Erstellungs-Fehler</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Benutzer__c</field>
            <value>
                <elementReference>for_UserFullName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Beschreibung__c</field>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>DatumZeit__c</field>
            <value>
                <elementReference>$System.OriginDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SektionObjekt__c</field>
            <value>
                <elementReference>var_ObjectName</elementReference>
            </value>
        </inputAssignments>
        <object>Monitoring__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <description>Selektierung des Objekts aus dem der ursprüngliche Fehler gemeldet wurde.</description>
        <name>get_Object</name>
        <label>get_Object</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>dec_ObjectExists</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>KeyPrefix</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>for_KeyPrefix</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>EntityDefinition</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>dec_varRec_Ok</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>

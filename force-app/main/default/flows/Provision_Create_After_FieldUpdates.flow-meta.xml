    <decisions>
        <description>Prüft, ob bei der Erstellung des Provisionsdatensatzes (Eingangskriterium) auf der Verkaufschance schon das Merkmal &apos;Kaufpreis bezahlt&apos; gesetzt ist.</description>
        <name>dec_KaufpreisBezahlt</name>
        <label>dec_KaufpreisBezahlt</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>dec_MaklerUser</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>dec_KaufpreisBezahlt_Nein</defaultConnectorLabel>
        <rules>
            <name>dec_KaufpreisBezahlt_Ja</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Verkaufschance__r.Kaufpreis_bezahlt__c</leftValueReference>
                <operator>EqualTo</operator>
            </conditions>
            <connector>
                <targetReference>ass_Provision_KaufpreisBezahlt</targetReference>
            </connector>
            <label>dec_KaufpreisBezahlt_Ja</label>
        </rules>
    </decisions>
    <decisions>
        <description>Prüft, ob bei der Erstellung des Provisionsdatensatzes (Eingangskriterium) auf der Verkaufschance schon das Merkmal &apos;1. MaBV Rate gezahlt&apos; gesetzt ist.</description>

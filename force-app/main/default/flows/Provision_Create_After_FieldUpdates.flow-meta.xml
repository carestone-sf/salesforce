    <decisions>
        <description>Prüft, ob bei der Erstellung des Provisionsdatensatzes (Eingangskriterium) der zugeordnete Makler KEIN Community-User ist.</description>
        <name>dec_MaklerUser</name>
        <label>dec_MaklerUser</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>updateProvision</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>dec_MaklerUser_Nein</defaultConnectorLabel>
        <rules>
            <name>dec_MaklerUser_Ja</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Makler__r.CommunityUser__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ass_Provision_MaklerUser</targetReference>
            </connector>
            <label>dec_MaklerUser_Ja</label>
        </rules>
    </decisions>

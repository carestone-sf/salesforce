    </formulas>
    <formulas>
        <name>buNumber</name>
        <dataType>String</dataType>
        <expression>IF(!{!IsSalesInvoice} &amp;&amp; NOT(Begins({!accountNoImmobilie}, &apos;1510&apos;)) &amp;&amp; {!MwstSatz} = 19, &apos;9&apos;, null)</expression>

    <formulas>
        <name>ClientId</name>
        <dataType>String</dataType>
        <expression>&apos;618558-&apos;+{!MandantenNummer}</expression>
    </formulas>
    <formulas>
        <name>CostNumber</name>
        <dataType>String</dataType>
        <expression>RPAD({!ImmobilienNummer}, 5, &apos;0&apos; )</expression>
    </formulas>
    <formulas>
        <name>costOne</name>
        <dataType>String</dataType>

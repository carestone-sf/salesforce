<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>KaufdatumNichtInDerZukunft</fullName>
    <active>true</active>
    <description>Das Kaufdatum darf nicht in der Zukunft liegen.</description>
    <errorConditionFormula>NOT(ISBLANK(Kaufdatum__c)) &amp;&amp; Kaufdatum__c &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Kaufdatum__c</errorDisplayField>
    <errorMessage>Das Kaufdatum darf nicht in der Zukunft liegen.</errorMessage>
</ValidationRule>

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ClosingBonusNotAvailable</fullName>
    <active>true</active>
    <errorConditionFormula>Not(IsBlank(Immobilie__r.ClosingBonusAb__c)) &amp;&amp; Notartermin__c &lt; Immobilie__r.ClosingBonusAb__c &amp;&amp; Not(IsBlank(ClosingBonusInProzent__c)) &amp;&amp; ClosingBonusInProzent__c != 0</errorConditionFormula>
    <errorDisplayField>ClosingBonusInProzent__c</errorDisplayField>
    <errorMessage>Der Notartermin war vor Beginn des Closing Bonus. Bitte entferne die Closing Provision.</errorMessage>
</ValidationRule>

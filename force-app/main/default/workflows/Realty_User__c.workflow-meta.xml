<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Aktivierung_ImmoRechner</fullName>
        <description>Aktivierung ImmoRechner</description>
        <protected>false</protected>
        <recipients>
            <recipient>witte@amstammtisch.de</recipient>
            <type>user</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/Neue_ImmoRechner_Registrierung</template>
    </alerts>
    <alerts>
        <fullName>Email_To_Notice_The_New_User</fullName>
        <description>Email To Notice The New User</description>
        <protected>false</protected>
        <recipients>
            <field>Email__c</field>
            <type>email</type>
        </recipients>
        <recipients>
            <field>Login_Email__c</field>
            <type>email</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/ImmoFinder_Registrierung</template>
    </alerts>
    <alerts>
        <fullName>Email_To_Notice_The_User_about_new_pass</fullName>
        <description>Email To Notice The User about new Passwort</description>
        <protected>false</protected>
        <recipients>
            <field>Email__c</field>
            <type>email</type>
        </recipients>
        <recipients>
            <field>Login_Email__c</field>
            <type>email</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/ImmoFinder_neue_PW</template>
    </alerts>
    <alerts>
        <fullName>ImmoBenutzer_im_System_nicht_bekannt</fullName>
        <description>ImmoBenutzer im System nicht bekannt</description>
        <protected>false</protected>
        <recipients>
            <field>Login_Email__c</field>
            <type>email</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/ImmoBenutzer_nicht_bekannt</template>
    </alerts>
    <alerts>
        <fullName>Neue_Anmeldung_im_ImmoFinder_intern</fullName>
        <description>Neue Anmeldung im ImmoFinder intern</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/Neue_Registrierung_im_ImmoFinder_intern</template>
    </alerts>
    <alerts>
        <fullName>Neue_Immofinder_Extern_Registrierung</fullName>
        <ccEmails>support@hyposerv.com</ccEmails>
        <description>Neue Immofinder Extern Registrierung</description>
        <protected>false</protected>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/Neue_Registrierung_im_ImmoFinder_intern</template>
    </alerts>
    <alerts>
        <fullName>Neue_Leads_in_der_Lead_B_rse</fullName>
        <description>Neue Leads in der Lead Börse</description>
        <protected>false</protected>
        <recipients>
            <field>Login_Email__c</field>
            <type>email</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>Standard/Neue_Leads_im_Maklerportal</template>
    </alerts>
    <alerts>
        <fullName>RaikErinnerung</fullName>
        <ccEmails>lubitz@amstammtisch.de</ccEmails>
        <description>RaikErinnerung</description>
        <protected>false</protected>
        <recipients>
            <recipient>witte@amstammtisch.de</recipient>
            <type>user</type>
        </recipients>
        <senderAddress>maklerbetreuung@wirtschaftshaus.de</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>WH_Systems/Errinerung_Raik</template>
    </alerts>
    <fieldUpdates>
        <fullName>Z_hler</fullName>
        <field>Z_hler__c</field>
        <formula>Z_hler__c + 1</formula>
        <name>Zähler</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>ImmoBenutzer nicht im System bekannt</fullName>
        <actions>
            <name>ImmoBenutzer_im_System_nicht_bekannt</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Realty_User__c.Im_System_nicht_bekannt__c</field>
            <operation>equals</operation>
            <value>Wahr</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Neue Anmeldung im ImmoFinder</fullName>
        <actions>
            <name>Neue_Anmeldung_im_ImmoFinder_intern</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <formula>ISCHANGED(OwnerId)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Neue Anmeldung im ImmoFinder HypoServ</fullName>
        <actions>
            <name>Neue_Immofinder_Extern_Registrierung</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Realty_User__c.Name</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Realty_User__c.Login_Email__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Realty_User__c.Herkunft__c</field>
            <operation>notEqual</operation>
            <value>WH Maklerportal</value>
        </criteriaItems>
        <criteriaItems>
            <field>Realty_User__c.Herkunft__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Realty_User__c.Active__c</field>
            <operation>equals</operation>
            <value>Falsch</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Reset Password Email Alert</fullName>
        <actions>
            <name>Email_To_Notice_The_User_about_new_pass</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <formula>Password__c  &lt;&gt;  PRIORVALUE( Password__c )&amp;&amp; Herkunft__c != &apos;HypoServ&apos;</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
